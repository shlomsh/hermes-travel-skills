# Copy to .env and fill in your own keys. Never commit the real .env.

# Google Maps Platform key — used by google_places AND google_weather.
# Enable "Places API (New)" and "Weather API" on this key's project.
GOOGLE_PLACES_API_KEY=your-google-maps-platform-key

# Optional: a separate key for weather. If unset, google_weather falls back
# to GOOGLE_PLACES_API_KEY above.
# GOOGLE_WEATHER_API_KEY=your-weather-key

# Aviationstack key — free tier: same-day, HTTP-only, 100 req/month.
AVIATIONSTACK_API_KEY=your-aviationstack-key
